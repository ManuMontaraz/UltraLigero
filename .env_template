# Branding
APP_NAME=UltraLigero
APP_URL=http://localhost:3000

# Frontend branding (Vite variables - must start with VITE_)
VITE_APP_NAME=UltraLigero
VITE_AUTHOR_NAME="Tu Nombre"
VITE_AUTHOR_EMAIL="tu@email.com"
VITE_AUTHOR_WEB="https://tuweb.com"
VITE_GITHUB_URL="https://github.com/tuusuario/turepo"

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contraseña_db
DB_NAME=ultraligero
DB_PORT=3306

# Server
PORT=3000
NODE_ENV=development

# Admin - Cambia esta contraseña en producción
ADMIN_PASSWORD=contraseña_segura_admin

# Referidos - Tu código de afiliado se añade automáticamente a URLs
AFFILIATE_TAG=ref=tu-codigo

# Uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=4194304
